--====================================
-- FUNÇÃO DE ARRASTE SUAVE
--====================================
local function MakeDraggable(obj)
    local dragging, dragInput, dragStart, startPos
    obj.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true; dragStart = input.Position; startPos = obj.Position
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then dragging = false end
            end)
        end
    end)
    obj.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then dragInput = input end
    end)
    RunService.RenderStepped:Connect(function()
        if dragging and dragInput then
            local delta = dragInput.Position - dragStart
            obj.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
end

--====================================
-- 1. MOTOR DE BANIMENTO (UNIVERSAL MANSION ENGINE)
--====================================
local function ExecutarBan(alvo)
    if not Config.Ativo or not Config.Running then return end 
    if not alvo or not alvo.Character then return end
    if table.find(Config.Whitelist, alvo.Name) then return end

    task.spawn(function()
        local hrpAlvo = alvo.Character:FindFirstChild("HumanoidRootPart")
        local meuHrp = Players.LocalPlayer.Character and Players.LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        
        if hrpAlvo and meuHrp then
            local oldPos = meuHrp.CFrame
            meuHrp.CFrame = hrpAlvo.CFrame * CFrame.new(0, 0, 1)

            -- GATILHO 1: REMOTE PADRÃO
            local Trigger = ReplicatedStorage:FindFirstChild("RE") and ReplicatedStorage.RE:FindFirstChild("1Playe1rTrigge1rEven1t")
            if Trigger then 
                pcall(function() Trigger:FireServer("BanPlayerFromHouse", alvo, alvo.Character) end) 
            end

            -- GATILHO 2: TELEMETRIA DINÂMICA (MANSÕES VIPS / NOVAS)
            -- Usa o ID detectado automaticamente (012, 013, 014...)
            local Telemetry = ReplicatedStorage:FindFirstChild("Remotes") and ReplicatedStorage.Remotes:FindFirstChild("TelemetryClientInteraction")
            if Telemetry and Config.LoteNome ~= "" then
                local args = {
                    "filterClick",
                    {
                        name = Config.LoteNome,
                        itemType = "Mansions"
                    }
                }
                pcall(function() Telemetry:FireServer(unpack(args)) end)
            end

            -- GATILHO 3: PERMISSÕES INTERNAS DA MANSÃO
            local lots = workspace:FindFirstChild("001_Lots") or workspace:FindFirstChild("Plots")
            if lots then
                for _, casa in pairs(lots:GetChildren()) do
                    local owner = casa:FindFirstChild("Owner")
                    if (owner and owner.Value == Players.LocalPlayer.Name) or casa.Name:find(Players.LocalPlayer.Name) then
                        local houseModel = casa:FindFirstChild("HousePickedByPlayer")
                        if houseModel then
                            local disallow = houseModel:FindFirstChild("Permissions:Disallow", true)
                            if disallow then pcall(function() disallow:FireServer(alvo) end) end
                        end
                    end
                end
            end

            RunService.Heartbeat:Wait()
            meuHrp.CFrame = oldPos
        end
    end)
end

