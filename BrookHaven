CloseBtn.MouseButton1Click:Connect(function() Main.Visible = false; OpenBtn.Visible = true end)
OpenBtn.MouseButton1Click:Connect(function() Main.Visible = true; OpenBtn.Visible = false end)

BtnMark.MouseButton1Click:Connect(function()
    local lots = workspace:FindFirstChild("001_Lots")
    if lots then
        for _, p in pairs(lots:GetChildren()) do
            if (p:FindFirstChild("Owner") and p.Owner.Value == LocalPlayer.Name) or p.Name:find(LocalPlayer.Name) then
                Config.LotePos = p:GetPivot().Position
                BtnMark.BackgroundColor3 = Color3.fromRGB(0, 80, 200); BtnMark.Text = "Home Sync ✓"
                return
            end
        end
    end
    BtnMark.Text = "Not Found!"; task.wait(1); BtnMark.Text = "Mark Home"
end)

BtnActive.MouseButton1Click:Connect(function()
    if not Config.LotePos then 
        BtnActive.Text = "Sync Home First!"; task.wait(1)
        BtnActive.Text = Config.Ativo and "Defense: ON" or "Defense: OFF"
        return 
    end
    Config.Ativo = not Config.Ativo
    BtnActive.Text = Config.Ativo and "Defense: ON" or "Defense: OFF"
    BtnActive.BackgroundColor3 = Config.Ativo and Color3.fromRGB(0, 150, 0) or Color3.fromRGB(40, 40, 40)
end)

BtnClear.MouseButton1Click:Connect(function()
    local oldState = Config.Ativo
    Config.Ativo = true -- Força para o Clear Land funcionar
    for _, p in pairs(Players:GetPlayers()) do if p ~= LocalPlayer then ExecutarBan(p) end end
    Config.Ativo = oldState
end)

--====================================
-- 5. EVENTOS E RADAR
--====================================
Players.PlayerAdded:Connect(UpdateList)
Players.PlayerRemoving:Connect(UpdateList)
UpdateList()

task.spawn(function()
    while task.wait(0.6) do
        -- HIERARQUIA: Só escaneia se o botão estiver ON
        if Config.Ativo and Config.LotePos then
            for _, p in pairs(Players:GetPlayers()) do
                if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                    local dist = (Config.LotePos - p.Character.HumanoidRootPart.Position).Magnitude
                    if dist < Config.DistanciaDefesa then 
                        ExecutarBan(p) 
                    end
                end
            end
        end
    end
end)
