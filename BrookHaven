--====================================
-- 1. MOTOR DE BANIMENTO (A CHAVE MESTRA)
--====================================
local function ExecutarBan(alvo)
    if not Config.Ativo then return end 
    if not alvo or not alvo.Character then return end
    if table.find(Config.Whitelist, alvo.Name) then return end

    task.spawn(function()
        local hrpAlvo = alvo.Character:FindFirstChild("HumanoidRootPart")
        local meuHrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        
        if hrpAlvo and meuHrp then
            local oldPos = meuHrp.CFrame
            meuHrp.CFrame = hrpAlvo.CFrame * CFrame.new(0, 0, 1)

            -- Banimento Híbrido (Normal + Wiki/Premium)
            local Trigger = ReplicatedStorage:FindFirstChild("RE") and ReplicatedStorage.RE:FindFirstChild("1Playe1rTrigge1rEven1t")
            if Trigger then pcall(function() Trigger:FireServer("BanPlayerFromHouse", alvo, alvo.Character) end) end

            local lots = workspace:FindFirstChild("001_Lots")
            if lots then
                for _, casa in pairs(lots:GetChildren()) do
                    local owner = casa:FindFirstChild("Owner")
                    if (owner and owner.Value == LocalPlayer.Name) or casa.Name:find(LocalPlayer.Name) then
                        local houseModel = casa:FindFirstChild("HousePickedByPlayer") and casa.HousePickedByPlayer:FindFirstChild("HouseModel")
                        if houseModel then
                            local permRemote = houseModel:FindFirstChild("Permissions:Disallow")
                            if permRemote then pcall(function() permRemote:FireServer(alvo) end) end
                        end
                    end
                end
            end

            RunService.Heartbeat:Wait()
            meuHrp.CFrame = oldPos
        end
    end)
end

