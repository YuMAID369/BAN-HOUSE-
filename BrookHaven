--====================================
-- 3. FUNÇÕES DE ATUALIZAÇÃO E LISTA
--====================================
local function UpdateList()
    for _, v in pairs(Scroll:GetChildren()) do if v:IsA("TextButton") then v:Destroy() end end
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer then
            local pBtn = Instance.new("TextButton", Scroll)
            pBtn.Size = UDim2.new(0.95, 0, 0, 35); pBtn.Text = p.DisplayName; pBtn.Font = "GothamBold"; pBtn.TextSize = 12; pBtn.TextColor3 = Color3.new(1,1,1)
            pBtn.BackgroundColor3 = table.find(Config.Whitelist, p.Name) and Color3.fromRGB(0, 120, 0) or Color3.fromRGB(30, 30, 30)
            Instance.new("UICorner", pBtn)

            pBtn.MouseButton1Click:Connect(function()
                local index = table.find(Config.Whitelist, p.Name)
                if index then
                    table.remove(Config.Whitelist, index)
                    pBtn.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
                else
                    table.insert(Config.Whitelist, p.Name)
                    pBtn.BackgroundColor3 = Color3.fromRGB(0, 120, 0)
                end
            end)
        end
    end
    Scroll.CanvasSize = UDim2.new(0, 0, 0, Layout.AbsoluteContentSize.Y + 10)
end

