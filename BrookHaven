-- LOGICA DE MARK HOME COM DETECÇÃO DE ID
BtnMark.MouseButton1Click:Connect(function()
    local lots = workspace:FindFirstChild("001_Lots") or workspace:FindFirstChild("Plots")
    if lots then
        for _, p in pairs(lots:GetChildren()) do
            local owner = p:FindFirstChild("Owner")
            if (owner and owner.Value == Players.LocalPlayer.Name) or p.Name:find(Players.LocalPlayer.Name) then
                Config.LotePos = p:GetPivot().Position
                
                -- DETECÇÃO DINÂMICA DO ID DA MANSÃO (Chave para 012, 013, 014...)
                local picked = p:FindFirstChild("HousePickedByPlayer")
                if picked then
                    local model = picked:FindFirstChildWhichIsA("Model")
                    if model then
                        Config.LoteNome = model.Name -- Captura "013_Mansion" ou qualquer outra
                    end
                end
                
                -- Fallback caso a detecção direta falhe, mas o lote seja mansão
                if Config.LoteNome == "" and p:FindFirstChild("MansionModel") then
                    Config.LoteNome = "013_Mansion" 
                end

                BtnMark.BackgroundColor3 = Color3.fromRGB(0, 80, 200); BtnMark.Text = "Universal Sync ✓"
                return
            end
        end
    end
    BtnMark.Text = "Not Found!"; task.wait(1); BtnMark.Text = "Marcar House"
end)

BtnActive.MouseButton1Click:Connect(function()
    if not Config.LotePos then 
        BtnActive.Text = "Sync Home First!"; task.wait(1); BtnActive.Text = Config.Ativo and "Defense: ON" or "Defense: OFF"
        return 
    end
    Config.Ativo = not Config.Ativo
    BtnActive.Text = Config.Ativo and "Defense: ON" or "Defense: OFF"
    BtnActive.BackgroundColor3 = Config.Ativo and Color3.fromRGB(0, 150, 0) or Color3.fromRGB(40, 40, 40)
end)

BtnClear.MouseButton1Click:Connect(function()
    local oldState = Config.Ativo
    Config.Ativo = true
    for _, p in pairs(Players:GetPlayers()) do if p ~= Players.LocalPlayer then ExecutarBan(p) end end
    Config.Ativo = oldState
end)

UpdateList()

--====================================
-- 4. RADAR DE DEFESA
--====================================
task.spawn(function()
    while Config.Running do
        if Config.Ativo and Config.LotePos then
            for _, p in pairs(Players:GetPlayers()) do
                if p ~= Players.LocalPlayer and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                    local dist = (Config.LotePos - p.Character.HumanoidRootPart.Position).Magnitude
                    local threshold = (Config.LoteNome:find("Mansion") or Config.LoteNome:find("01")) and 210 or Config.DistanciaDefesa
                    if dist < threshold then 
                        ExecutarBan(p) 
                    end
                end
            end
        end
        task.wait(0.6)
    end
end)